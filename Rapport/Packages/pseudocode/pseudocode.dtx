%    \begin{macrocode}
\newcommand{\fonction}[6]{
  \instruction{\textbf{\motclefFonction} #1 \textbf{(}#2\textbf{)} \textbf{:} #3}
  \preconditions{#4}
  \ifx\empty#5\empty
  \else
  \variables{#5}
  \fi
  \debutfin{#6}
}
