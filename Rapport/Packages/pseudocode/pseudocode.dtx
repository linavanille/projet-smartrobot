%% \#1 : Nom de la fonction \\
%% \#2 : Paramètres formels \\
%% \#3 : Type de retour \\
%% \#4 : Préconditions (peut être vide) \\
%% \#5 : Déclaration des variables locales (peut être vide) \\
%% \#6 : Instructions
% \end{boite}
% \textbf{Exemple :}
% \begin{lstsample}{\lstset{framesep=2pt}}{}
%    \begin{algorithme}
%    \fonction{division}
%       {a, b : \reel}{\reel}
